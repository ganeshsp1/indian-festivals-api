        .banner-subheading {
          font-size: 16px;
        }

        .m-web-button {
          width: 100%;
          font-size: 11px;
          display: block;
          padding: 8px;
          max-width: 100%;
          font-size: 16px;
          position: relative;
          z-index: 5;
        }

        .banner-heading {
          font-size: 26px;
          line-height: 120%;
        }

        .banner-hero-image {
          display: none;
        }

        .webinar-banner-cta {
          padding: 30px 30px;
          padding-top: 44px;
          width: 90%;
        }

        .left-section {
          margin-right: 0px;
          padding-left: 0px;
        }

        .form-group .input-box {
          width: 90%;
        }

        .phone-group .input-box {
          width: 65%;
        }

        .banner-deadline-image {
          width: 100%;
